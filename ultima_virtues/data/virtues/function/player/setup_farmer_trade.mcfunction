# virtues:player/setup_farmer_trade
# Called every tick for all villagers. Named farmers get custom trade chains.
# Unnamed villagers are untouched and keep vanilla trades.

# --- Fannie Mae ---
execute if entity @s[name="Fannie Mae"] if data entity @s Offers if data entity @s VillagerData{level:1} run data modify entity @s Offers.Recipes set value [{buy:{id:"minecraft:brown_mushroom",count:2},sell:{id:"minecraft:red_mushroom",count:1},maxUses:999999,xp:10}]
